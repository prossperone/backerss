  <div class="toast mono" id="toast">¡RETO COMPLETADO! CAPÍTULO SUPERADO</div>

  <script>
  (function () {
    // 1. Manejo de Checklists Tradicionales
    var normalItems = document.querySelectorAll('.normal-check, #cardReto2 .check-item, #cardReto3 .check-item, #cardReto4 .check-item');
    
    normalItems.forEach(function (item) {
      item.addEventListener('click', function () {
        item.classList.toggle('checked');
        recalcChecklistCounters();
        checkReto1GlobalStatus();
      });
      item.setAttribute('role', 'checkbox');
      item.setAttribute('tabindex', '0');
    });

    // 2. Control del Diagnóstico Abierto (Punto 4 del Reto 1)
    var diagnosticItem = document.getElementById('diagnosticItem');
    var diagButtons = document.querySelectorAll('.diag-btn');
    var selectedDiagnosticScenario = null;

    diagButtons.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        
        diagButtons.forEach(el => el.classList.remove('active'));
        
        if (selectedDiagnosticScenario === btn.getAttribute('data-type')) {
          selectedDiagnosticScenario = null;
          diagnosticItem.classList.remove('checked');
        } else {
          btn.classList.add('active');
          selectedDiagnosticScenario = btn.getAttribute('data-type');
          diagnosticItem.classList.add('checked');
        }

        recalcChecklistCounters();
        checkReto1GlobalStatus();
      });
    });

    // Recalcular dinámicamente los contadores visuales (0 / 4)
    function recalcChecklistCounters() {
      var card1 = document.getElementById('cardReto1');
      var checkedInCard1 = card1.querySelectorAll('.check-item.checked').length;
      document.getElementById('checklistCount').textContent = checkedInCard1 + ' / 4';

      ['cardReto2', 'cardReto3', 'cardReto4'].forEach(id => {
        var card = document.getElementById(id);
        if (card) {
          var total = card.querySelectorAll('.check-item').length;
          var checked = card.querySelectorAll('.check-item.checked').length;
          var display = card.querySelector('.checklist-head span.mono');
          if (display) display.textContent = checked + ' / ' + total;
        }
      });
    }

    // 3. Control Global de Meta y Botón Final del Reto 1
    var contactCount = document.getElementById('contactCount');
    var vaultAmount = document.getElementById('vaultAmount');
    var completeBtn = document.getElementById('completeBtn');
    var toast = document.getElementById('toast');
    
    var TARGET = 20;
    var realContactsConseguidos = 0;

    function checkReto1GlobalStatus() {
      var metaContactosCumplida = realContactsConseguidos >= TARGET;
      var checkedInCard1 = document.getElementById('cardReto1').querySelectorAll('.check-item.checked').length;
      var checklistCompleto = checkedInCard1 === 4;

      if (metaContactosCumplida && checklistCompleto) {
        completeBtn.classList.add('is-ready');
        completeBtn.style.cursor = 'pointer';
      } else {
        completeBtn.classList.remove('is-ready');
        completeBtn.style.cursor = 'not-allowed';
      }
    }

    completeBtn.addEventListener('click', function () {
      if (!completeBtn.classList.contains('is-ready')) return;
      toast.classList.add('is-visible');
      setTimeout(function () { toast.classList.remove('is-visible'); }, 3200);
      
      var card2 = document.getElementById('cardReto2');
      if (card2) card2.classList.remove('is-locked');
    });

    // Copiar link de página de captura
    var copyLinkBtn = document.getElementById('copyLinkBtn');
    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', function () {
        var linkValue = 'https://backerss.com/captura.html?ref=TU-NOMBRE';
        navigator.clipboard.writeText(linkValue).then(function () {
          copyLinkBtn.innerHTML = 'Copiado ✓';
          setTimeout(function () {
            copyLinkBtn.innerHTML = 'Copiar';
          }, 2000);
        });
      });
    }

    // ---------- Constelación: Simulación corregida a $12 por registro ----------
    var addBackerBtn = document.getElementById('addBackerBtn');
    var constellationField = document.getElementById('constellationField');
    var constellationCount = document.getElementById('constellationCount');

    if (addBackerBtn) {
      addBackerBtn.addEventListener('click', function () {
        realContactsConseguidos++;
        
        var node = document.createElement('div');
        node.className = 'backer-node';
        node.innerHTML = '<span class="dot"></span><span class="tag mono">B' + realContactsConseguidos + '</span>';
        constellationField.insertBefore(node, addBackerBtn);
        
        constellationCount.textContent = realContactsConseguidos + (realContactsConseguidos === 1 ? ' Backer' : ' Backers');
        
        var capped = Math.min(realContactsConseguidos, TARGET);
        contactCount.textContent = capped + ' / ' + TARGET;
        
        // CORRECCIÓN CLAVE: Multiplicador actualizado científicamente a $12 por registro
        vaultAmount.textContent = '$' + (realContactsConseguidos * 12).toFixed(0);
        
        checkReto1GlobalStatus();
      });
    }
  })();
  </script>
