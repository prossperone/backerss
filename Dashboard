<script>
(function () {
  var items = document.querySelectorAll('.check-item');
  var contactCount = document.getElementById('contactCount');
  var checklistCount = document.getElementById('checklistCount');
  var vaultAmount = document.getElementById('vaultAmount');
  var completeBtn = document.getElementById('completeBtn');
  var toast = document.getElementById('toast');

  var TARGET = 20;
  var totalItems = items.length;
  
  // Variable global de simulación para los contactos reales conseguidos
  var realContactsConseguidos = 0; 

  function recalc() {
    var checkedCount = 0;
    items.forEach(function (item) {
      if (item.classList.contains('checked')) {
        checkedCount++;
      }
    });
    
    // El checklist muestra su propio progreso
    checklistCount.textContent = checkedCount + ' / ' + totalItems;
    
    // Evaluamos si el usuario alcanzó la meta mínima de 20 contactos en su constelación
    var ready = realContactsConseguidos >= TARGET;
    completeBtn.classList.toggle('is-ready', ready);
  }

  items.forEach(function (item) {
    item.addEventListener('click', function () {
      item.classList.toggle('checked');
      recalc();
    });
    item.setAttribute('role', 'checkbox');
    item.setAttribute('tabindex', '0');
    item.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        item.click();
      }
    });
  });

  completeBtn.addEventListener('click', function () {
    if (!completeBtn.classList.contains('is-ready')) return;
    toast.classList.add('is-visible');
    setTimeout(function () { toast.classList.remove('is-visible'); }, 3200);
  });

  // ---------- Copiar link de página de captura ----------
  var copyLinkBtn = document.getElementById('copyLinkBtn');
  if (copyLinkBtn) {
    copyLinkBtn.addEventListener('click', function () {
      var linkValue = 'https://backerss.com/captura.html?ref=TU-NOMBRE';
      navigator.clipboard.writeText(linkValue).then(function () {
        copyLinkBtn.classList.add('is-copied');
        copyLinkBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg> Copiado';
        setTimeout(function () {
          copyLinkBtn.classList.remove('is-copied');
          copyLinkBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copiar';
        }, 2000);
      });
    });
  }

  // ---------- Constelación: Llenado interactivo real ----------
  var addBackerBtn = document.getElementById('addBackerBtn');
  var constellationField = document.getElementById('constellationField');
  var constellationCount = document.getElementById('constellationCount');

  if (addBackerBtn) {
    addBackerBtn.addEventListener('click', function () {
      realContactsConseguidos++;
      
      // Crear nodo visual brillante en la constelación
      var node = document.createElement('div');
      node.className = 'backer-node';
      node.innerHTML = '<span class="dot"></span><span class="tag mono">B' + realContactsConseguidos + '</span>';
      constellationField.insertBefore(node, addBackerBtn);
      
      // Actualizar contadores interactivos
      constellationCount.textContent = realContactsConseguidos + (realContactsConseguidos === 1 ? ' Backer' : ' Backers');
      
      // El contador de la misión sube orgánicamente
      var capped = Math.min(realContactsConseguidos, TARGET);
      contactCount.textContent = capped + ' / ' + TARGET;
      
      // Cada contacto real en el simulador se visualiza en la Bóveda ($12 por registro de Ciclo 1)
      vaultAmount.textContent = '$' + (realContactsConseguidos * 12).toFixed(0);
      
      recalc();
    });
  }

  // ---------- Video modal ----------
  var openBtn = document.getElementById('openVideoModal');
  var overlay = document.getElementById('videoModalOverlay');
  var closeBtn = document.getElementById('vmCloseBtn');
  var placeholder = document.getElementById('vmPlaceholder');

  function openModal() {
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  if (openBtn) openBtn.addEventListener('click', openModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);

  if (overlay) {
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeModal();
    });
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
  });

  if (placeholder) {
    placeholder.addEventListener('click', function () {
      placeholder.querySelector('.vm-ph-label').textContent = 'Conecta tu video real aquí';
    });
  }

  recalc();
})();
</script>
</body>
</html>
